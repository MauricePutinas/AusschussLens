# --- AusschussLens Backend Konfiguration ---
# Laeuft OHNE Key im Mock-Modus (deterministischer 8D-Entwurf).
# Fuer echte KI-Reports + Foto-Analyse einfach den Key setzen:

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# LLM_PROVIDER=auto         # auto | mock | anthropic

# CORS_ORIGINS=*
# DB_PATH=./app/data/ausschusslens.db
# UPLOAD_DIR=./app/data/uploads
